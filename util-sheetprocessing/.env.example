# Google Sheets - 서비스 계정 JSON 키 파일 경로
GCP_SERVICE_ACCOUNT_FILE=./credentials/service_account.json

# 구글 시트 이름 (URL이 아닌 시트 문서 제목)
SHEET_NAME=My_Database

# 입력 워크시트 탭 이름
INPUT_WORKSHEET=Input_Data

# 결과 출력 워크시트 탭 이름
OUTPUT_WORKSHEET=Output_Data

# Gemini API Key (https://aistudio.google.com/apikey 에서 발급)
GEMINI_API_KEY=your_gemini_api_key_here

# LLM 모델명
LLM_MODEL=gemini-2.5-flash

# 그룹핑 기준 컬럼명
GROUP_COLUMN=Group_ID

# 병합 대상 텍스트 컬럼명
TEXT_COLUMN=Raw_Text

# API 호출 간 대기 시간 (초) - Rate Limit 방어
API_DELAY_SECONDS=1.0
